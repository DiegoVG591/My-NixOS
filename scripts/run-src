#!/usr/bin/env bash

# Usage: run-src [-p] file (in nvim <leader> + r to run in non pager mode and <leader> + R for pager mode)
# flag -p is for pager mode for output-heavy non-interactive runs

# --- GLOBAL VARIABLES --- #
PAGER_MODE=false
PAUSE_COMMAND="echo; echo -n 'Press ENTER to close pane... '; read -r _"
INITIAL_DIR="${PWD}"

# --- MAIN --- #
main() {

  # tmux guard clause
  if [[ -z "${TMUX}" ]]; then
      echo "run-src needs a tmux session (your shell should have opened one — check .zshrc.personal)"
      exit 1
  fi

  while getopts "p" flag; do
    case "$flag" in
      p) PAGER_MODE=true ;;
      ?) echo "Usage: run-src [-p] file"
        exit 1 
      ;;
    esac
  done
  shift $((OPTIND - 1))

  # zero params guard clause
  if (( $# == 0)); then
      echo "No file target passed, please pass the file you want to run"
      echo "Usage: run-src [-p] file"
      exit 1
  fi


# Iterate through all passed paths
for FILE_PATH in "$@"; do

    cd "${INITIAL_DIR}" || continue # back to the invocation dir so relative paths resolve per-file

    # get current file real path
    FILE_PATH=$(realpath "${FILE_PATH}")
    echo "File path:  ${FILE_PATH}"

  # File path guard clauses
  if [[ -z "${FILE_PATH}" ]]; then 
    echo "Usage: run-src [-p] file"
    continue
  elif [[ -d "${FILE_PATH}" ]]; then
      echo "skipping: ${FILE_PATH}, it's a directory"
      echo "Usage: run-src [-p] file"
      continue
  elif  [[ ! -f "${FILE_PATH}" ]]; then
    echo "No such file: ${FILE_PATH}"
    echo "Usage: run-src [-p] file"
    continue
  fi

  # get file info and commands + bin subdir creation
  get_file_info
  cd "${DIRECTORY}" || continue
  get_commands || continue

  if [[ -n "${COMPILE_COMMAND}" ]]; then
      ${COMPILE_COMMAND} || continue # skip file if compile fails — NOTE: filenames with spaces unsupported
  fi

  # --- Launch --- #
  
  # pane fires the signal when done; script parks until then — one pane at a time
  if ${PAGER_MODE}; then
      tmux split-window -v "${RUN_COMMAND} | less -R; tmux wait-for -S done-signal-$$" 
      tmux wait-for done-signal-$$
      continue
  fi
  tmux split-window -v "${RUN_COMMAND}; ${PAUSE_COMMAND}; tmux wait-for -S done-signal-$$"
  tmux wait-for done-signal-$$
done
}

# --- FUNCS --- #
get_file_info() {
  EXTENSION="${FILE_PATH##*.}"
  FULL_NAME="${FILE_PATH##*/}"
  BASE_NAME="${FULL_NAME%.*}"
  if [[ "$FILE_PATH" == */* ]]; then
      DIRECTORY="${FILE_PATH%/*}"
      return
  fi
  DIRECTORY="./"
}


# Get run and compile commands, and mkdirs bins
get_commands() {
  case "$EXTENSION" in
    cpp)
      mkdir -p "bin/${EXTENSION}" || return 1
      COMPILE_COMMAND="g++ ${FULL_NAME} -o bin/${EXTENSION}/${BASE_NAME}"
      RUN_COMMAND="./bin/${EXTENSION}/${BASE_NAME}"
      ;;
    c)
      mkdir -p "bin/${EXTENSION}" || return 1
      COMPILE_COMMAND="gcc ${FULL_NAME} -o bin/${EXTENSION}/${BASE_NAME}"
      RUN_COMMAND="./bin/${EXTENSION}/${BASE_NAME}"
      ;;
    java)
      mkdir -p "bin/${EXTENSION}" || return 1
      COMPILE_COMMAND="javac -d bin/${EXTENSION} ${FULL_NAME}"
      RUN_COMMAND="java -cp bin/${EXTENSION} ${BASE_NAME}"
    ;;
    py)
      COMPILE_COMMAND=""
      RUN_COMMAND="python3 ${FULL_NAME}"
    ;;
    *)
      local file_header
      file_header=$(head -n 1 "${FULL_NAME}")
      if [[ "${file_header}" != "#!"* ]]; then
        echo "Unidentified extension:  ${EXTENSION}"
        return 1 
      fi
      handle_shebang || return 1 # returns 1 if user declines +x
    ;;
  esac
}

handle_shebang() {
    COMPILE_COMMAND=""
    RUN_COMMAND="./${FULL_NAME}"

    # Safety check
    read -rp "'${FULL_NAME}' needs +x to run. Grant it? (y/N) " confirm
    if [[ "$confirm" != [yY] ]]; then
        echo "Aborted."
        return 1
    fi

    chmod +x "${FULL_NAME}"
    echo "+x granted."
}

main "$@"


